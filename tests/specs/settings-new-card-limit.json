[
  {
    "name": "Daily New-Card Limit shows limit picker",
    "steps": [
      {
        "send": { "callback": "settings:new_card_limit" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Current daily new-card limit: 10\n\nHow many new cards per day?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Daily New-Card Limit can be changed via button",
    "steps": [
      {
        "send": { "callback": "settings:new_card_limit" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Current daily new-card limit: 10\n\nHow many new cards per day?"
            }
          }
        ]
      },
      {
        "send": { "callback": "settings:set_limit:20" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Daily new-card limit set to 20."
            }
          }
        ]
      }
    ]
  }
]
