[
  {
    "name": "Import Starter Decks imports pre-built decks",
    "steps": [
      {
        "send": { "callback": "deck:import_starter" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Imported Common Words and Useful Phrases with 10 cards."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Import Starter Decks shows already imported message",
    "steps": [
      {
        "send": { "callback": "deck:import_starter" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Imported Common Words and Useful Phrases with 10 cards."
            }
          }
        ]
      },
      {
        "send": { "callback": "deck:import_starter" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Starter decks are already imported."
            }
          }
        ]
      }
    ]
  }
]
