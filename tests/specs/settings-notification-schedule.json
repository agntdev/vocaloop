[
  {
    "name": "Notification Schedule shows time picker",
    "steps": [
      {
        "send": { "callback": "settings:notification_schedule" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Current reminder time: 09:00\n\nWhen should we remind you to review?"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Notification Schedule can be changed via button",
    "steps": [
      {
        "send": { "callback": "settings:notification_schedule" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Current reminder time: 09:00\n\nWhen should we remind you to review?"
            }
          }
        ]
      },
      {
        "send": { "callback": "settings:set_notif:18:00" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Reminder set for 18:00.\n\nWhen should we remind you to review?"
            }
          }
        ]
      }
    ]
  }
]
