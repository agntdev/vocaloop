[
  {
    "name": "Full review session flow",
    "steps": [
      {
        "send": { "callback": "deck:import_starter" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "✅ Imported Common Words and Useful Phrases with 10 cards."
            }
          }
        ]
      },
      {
        "send": { "callback": "review:start" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📝 Choose a deck to review:"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Empty session shows friendly message when no cards are due",
    "steps": [
      {
        "send": { "callback": "review:start" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "🎉 All caught up — no cards due right now. Add more cards or check back later."
            }
          }
        ]
      }
    ]
  }
]
